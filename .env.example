# Path to your local media directory (mounted read-only into containers)
MEDIA_PATH=/mnt/media

# Which GPU to use (nvidia-smi index). On a shared box, pin to the GPU
# with the most free VRAM so you don't fight other workloads.
GPU_DEVICE_ID=1

# Whisper model size: tiny, base, small, medium, large-v3
# large-v3 is the most accurate (~3 GB download, ~10 GB VRAM in float16)
WHISPER_MODEL=large-v3

# Local LLM for AI Q&A (any HuggingFace instruction-tuned text-generation model)
# Llama 3.2 3B is the default; smaller/larger options:
#   meta-llama/Llama-3.2-1B-Instruct   (fastest, least VRAM)
#   mistralai/Mistral-7B-Instruct-v0.3 (smartest, ~16 GB VRAM in float16)
LLM_MODEL=meta-llama/Llama-3.2-3B-Instruct

# Sentence embedding model (downloads automatically on first run)
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# CLIP vision model (downloads automatically on first run)
# ViT-Large gives noticeably better visual scene search than ViT-Base (~1.7 GB)
VISION_MODEL=openai/clip-vit-large-patch14

# HuggingFace token — required for pyannote.audio speaker diarization,
# and for gated Llama models (accept the license on the model page first)
# Get one at https://huggingface.co/settings/tokens
# Then accept pyannote/speaker-diarization-3.1 terms at https://hf.co/pyannote/speaker-diarization-3.1
# And Llama terms at https://hf.co/meta-llama/Llama-3.2-3B-Instruct
HF_TOKEN=hf_your_token_here
