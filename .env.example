# Path to your local media directory (mounted read-only into containers)
MEDIA_PATH=/mnt/media

# Optional second media source (e.g. an SMB/NFS mount). Mounted read-only at
# /media2 inside the containers; the watcher covers it automatically.
# Leave unset to use a harmless empty default (./sample_media_2).
# MEDIA_PATH_2=/mnt/ipv-ai

# Directory where browser uploads are stored (writable; created automatically)
UPLOAD_PATH=./uploads

# Which GPU to use (nvidia-smi index). On a shared box, pin to the GPU
# with the most free VRAM so you don't fight other workloads.
# GPU_DEVICE_ID: primary AI GPU (api Q&A LLM + worker-gpu).
# GPU2_DEVICE_ID: second GPU worker (worker-gpu-2) — pin to the OTHER card so
# GPU jobs (transcribe, diarize, embed, scenes) spread across both GPUs.
GPU_DEVICE_ID=1
GPU2_DEVICE_ID=0

# GPU used for NVENC hardware video encoding (proxy generation).
# IMPORTANT: verify NVENC actually works on the chosen index before pinning it —
# some GPU/driver combos reject encode sessions ("unsupported device (2)") even
# though CUDA works fine on the same card (e.g. RTX 5090 on driver 580.x, while
# an RTX PRO 6000 in the same box encodes fine). Test per index with:
#   docker run --rm --gpus 'device=N' -e NVIDIA_DRIVER_CAPABILITIES=all \
#     -v /path/to/ffmpeg:/f:ro ubuntu:22.04 /f -f lavfi \
#     -i testsrc=duration=1:size=640x360:rate=30 -c:v h264_nvenc -f null -
NVENC_GPU_DEVICE_ID=1

# Whisper model size: tiny, base, small, medium, large-v3
# large-v3 is the most accurate (~3 GB download, ~10 GB VRAM in float16)
WHISPER_MODEL=large-v3

# Local LLM for AI Q&A (any HuggingFace instruction-tuned text-generation model)
# Qwen 3 is UNGATED — no HuggingFace access approval needed. Options:
#   Qwen/Qwen3-4B               (faster, ~9 GB VRAM)
#   Qwen/Qwen3-8B               (default, ~17 GB VRAM)
#   Qwen/Qwen2.5-7B-Instruct    (previous default)
LLM_MODEL=Qwen/Qwen3-8B

# Sentence embedding model (downloads automatically on first run, ~2.3 GB)
# BAAI/bge-m3 is multilingual and much stronger than MiniLM for retrieval.
# Changing this requires rebuilding the search index (Jobs → Rebuild Search Index).
EMBEDDINGS_MODEL=BAAI/bge-m3

# Vision model for visual scene search (downloads automatically, ~4.5 GB)
# SigLIP-2 so400m substantially beats CLIP ViT-L for text→image retrieval.
# Changing this requires rebuilding the search index (Jobs → Rebuild Search Index).
VISION_MODEL=google/siglip2-so400m-patch14-384

# Translation model: MADLAD-400 3B (default) or facebook/nllb-200-distilled-600M
TRANSLATE_MODEL=google/madlad400-3b-mt

# Speaker diarization pipeline (pyannote.audio 4.x)
DIARIZATION_MODEL=pyannote/speaker-diarization-community-1

# YouTube publishing (optional). Create an OAuth client (Desktop app) in Google
# Cloud Console with the YouTube Data API v3 enabled, then obtain a refresh
# token for the channel you want to upload to (one-time OAuth consent flow).
# Leave blank to disable the Publish button in the UI.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
# Optional: plain API key used for the hourly published-video stats sync
# (views/likes/comments). Falls back to the OAuth trio above if unset.
YOUTUBE_API_KEY=

# HuggingFace token — required for pyannote.audio speaker diarization
# (instant approval: accept terms at https://hf.co/pyannote/speaker-diarization-community-1)
# Get a token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Cloned-voice dubbing engine: "chatterbox" (default, more natural) or "xtts".
# Chatterbox falls back to XTTS-v2 automatically if it fails to load.
DUB_ENGINE=chatterbox

# ── Graphics generator (ComfyUI) ──────────────────────────────────────────────
# URL of your existing ComfyUI install, as seen FROM INSIDE the containers.
# host.docker.internal resolves to the Docker host — ComfyUI must listen on
# 0.0.0.0 (start it with --listen) or at least on the docker bridge.
COMFYUI_URL=http://host.docker.internal:8188
# Running two ComfyUI instances (one for images, one for video)? Point each
# kind at its own instance; anything unset falls back to COMFYUI_URL.
# COMFYUI_URL_IMAGE=http://host.docker.internal:8188
# COMFYUI_URL_VIDEO=http://host.docker.internal:8189
# Host folder with custom ComfyUI workflow JSONs ("Export (API format)").
# Each file appears as an extra preset on the Graphics page.
COMFY_WORKFLOWS_PATH=./comfy_workflows
