# Path to your local media directory (mounted read-only into containers)
MEDIA_PATH=/mnt/media

# Directory where browser uploads are stored (writable; created automatically)
UPLOAD_PATH=./uploads

# Which GPU to use (nvidia-smi index). On a shared box, pin to the GPU
# with the most free VRAM so you don't fight other workloads.
GPU_DEVICE_ID=1

# GPU used for NVENC hardware video encoding (proxy generation).
# Defaults to 0 (e.g. RTX 5090) so encoding doesn't compete with AI inference.
NVENC_GPU_DEVICE_ID=0

# Whisper model size: tiny, base, small, medium, large-v3
# large-v3 is the most accurate (~3 GB download, ~10 GB VRAM in float16)
WHISPER_MODEL=large-v3

# Local LLM for AI Q&A (any HuggingFace instruction-tuned text-generation model)
# Qwen 2.5 is UNGATED — no HuggingFace access approval needed. Options:
#   Qwen/Qwen2.5-3B-Instruct    (faster, ~7 GB VRAM)
#   Qwen/Qwen2.5-7B-Instruct    (default, ~16 GB VRAM)
#   Qwen/Qwen2.5-14B-Instruct   (smarter, ~30 GB VRAM)
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Sentence embedding model (downloads automatically on first run)
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# CLIP vision model (downloads automatically on first run)
# ViT-Large gives noticeably better visual scene search than ViT-Base (~1.7 GB)
VISION_MODEL=openai/clip-vit-large-patch14

# YouTube publishing (optional). Create an OAuth client (Desktop app) in Google
# Cloud Console with the YouTube Data API v3 enabled, then obtain a refresh
# token for the channel you want to upload to (one-time OAuth consent flow).
# Leave blank to disable the Publish button in the UI.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# HuggingFace token — required for pyannote.audio speaker diarization
# (instant approval: accept terms at https://hf.co/pyannote/speaker-diarization-3.1)
# Get a token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here
